# ============================================================
# Evolution API v2 - variaveis de ambiente (free tier)
# Cole estas no painel da Koyeb (Environment variables) OU use
# num docker-compose local. Marque as marcadas com (SECRET).
# ============================================================

# ---- Servidor ----
SERVER_PORT=8080
SERVER_TYPE=http

# ---- Autenticacao (SECRET) ----
# Gere uma chave forte, ex: openssl rand -hex 32
AUTHENTICATION_API_KEY=TROQUE_POR_UMA_CHAVE_FORTE_AQUI

# ---- Banco de dados: Postgres no Neon (OBRIGATORIO na v2) ----
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# (SECRET) connection string do Neon (neon.tech). Tem que ter sslmode=require.
# Ex: postgresql://USER:SENHA@ep-xxxx.sa-east-1.aws.neon.tech/evolution?sslmode=require
DATABASE_CONNECTION_URI=postgresql://USER:SENHA@HOST.neon.tech/evolution?sslmode=require
DATABASE_CONNECTION_CLIENT_NAME=proteinaja
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true

# ---- Cache: Redis desligado, usa cache local (1 servico a menos) ----
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

# ---- Logs ----
LOG_LEVEL=ERROR,WARN
LOG_BAILEYS=error

# ---- (Opcional) Webhook global para o seu backend FastAPI no Render ----
# WEBHOOK_GLOBAL_ENABLED=true
# WEBHOOK_GLOBAL_URL=https://proteinaja-backend.onrender.com/webhook/whatsapp
